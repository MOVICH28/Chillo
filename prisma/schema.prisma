generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id        String   @id @default(cuid())
  question  String
  category  String
  yesPool   Float    @default(0)
  noPool    Float    @default(0)
  totalPool Float    @default(0)
  status    String   @default("open") // open | closed | resolved
  endsAt    DateTime
  createdAt DateTime @default(now())

  bets Bet[]
}

model Bet {
  id            String   @id @default(cuid())
  roundId       String
  walletAddress String
  side          String   // yes | no
  amount        Float
  odds          Float
  txHash        String   @unique
  createdAt     DateTime @default(now())

  round Round @relation(fields: [roundId], references: [id])
}

model Referral {
  id              String   @id @default(cuid())
  referrerAddress String
  referredAddress String   @unique
  createdAt       DateTime @default(now())
}
