generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id              String     @id @default(cuid())
  question        String
  category        String
  yesPool         Float      @default(0)
  noPool          Float      @default(0)
  totalPool       Float      @default(0)
  status          String     @default("open") // open | closed | resolved
  endsAt          DateTime
  createdAt       DateTime   @default(now())
  targetPrice     Float?
  targetToken     String?    // "bitcoin" | "solana"
  tokenList       String?    // JSON array of pump.fun token addresses
  resolvedAt      DateTime?
  winner          String?    // "yes" | "no" — kept for pumpfun rounds
  outcomes        Json?      // Array of {id,label,minPrice,maxPrice,pool} for range rounds
  bettingClosesAt DateTime?  // endsAt minus 5 min — betting locked after this
  winningOutcome  String?    // "A"|"B"|"C"|"D" — set on resolution of range rounds
  roundNumber     Int?       // sequential round number, null for old rounds
  lmsrB           Float      @default(100) // LMSR liquidity parameter
  shares          Json?      // {A: 0, B: 0, ...} total shares per outcome
  // Custom market fields
  isCustom        Boolean    @default(false)
  creatorId       String?
  creatorFee      Float      @default(0)
  description     String?
  twitterUrl      String?
  customImage     String?
  tokenAddress    String?    // contract address for custom tokens
  tokenSymbol     String?    // e.g. "BONK", "WIF"
  tokenLogo       String?    // logo URL
  // Twitter market fields
  twitterUsername    String?   // @username being tracked
  twitterUserId      String?   // Twitter user ID for API calls
  twitterQuestion    String?   // "posts_count" | "next_post_time"
  twitterPeriodHours Int?      // period in hours (24 for posts count)
  twitterLastChecked DateTime? // last time we checked Twitter API
  twitterPostCount   Int?      // cached post count (for posts_count type)
  questionType       String?   // "price" | "ath_mcap" | "mcap" — for custom crypto markets
  maxObservedMcap    Float?    // highest mcap seen during round lifetime (for ath_mcap resolution)
  isPumpFun          Boolean   @default(false) // detected or manually flagged pump.fun token
  creator         User?      @relation("CreatedRounds", fields: [creatorId], references: [id])
  positions       Position[]
  trades          Trade[]
}

model User {
  id            String     @id @default(cuid())
  username      String     @unique
  email         String     @unique
  passwordHash  String
  doraBalance   Float      @default(1000)
  avatarUrl     String?
  createdAt           DateTime   @default(now())
  lastMarketCreatedAt DateTime?
  referralCode        String?    @unique
  referredBy          String?
  referralEarnings    Float      @default(0)
  bets                Bet[]
  comments            Comment[]
  followers           Follow[]   @relation("following")
  following           Follow[]   @relation("follower")
  positions           Position[]
  trades              Trade[]
  createdRounds       Round[]    @relation("CreatedRounds")
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  roundId   String
  outcome   String
  shares    Float
  avgCost   Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  round     Round    @relation(fields: [roundId], references: [id])
  @@unique([userId, roundId, outcome])
}

model Trade {
  id          String   @id @default(cuid())
  userId      String
  roundId     String
  outcome     String
  type        String   // "buy" | "sell"
  shares      Float
  price       Float    // cost per share at time of trade
  totalCost   Float    // total DORA spent (positive=buy) or received negative=sell)
  fee         Float    // 1% platform fee
  profitLoss  Float?   // sell only: proceeds - cost basis
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  round       Round    @relation(fields: [roundId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("follower", fields: [followerId], references: [id])
  following   User     @relation("following", fields: [followingId], references: [id])
  @@unique([followerId, followingId])
}

model Comment {
  id        String   @id @default(cuid())
  roundId   String
  userId    String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Bet {
  id            String   @id @default(cuid())
  roundId       String
  walletAddress String
  side          String   // yes | no
  amount        Float
  odds          Float
  txHash        String   @unique
  status        String   @default("verified") // verified | unverified
  result        String?  // yes | no — set when round is resolved
  payout        Float?   // SOL amount sent to winner
  paid          Boolean  @default(false)
  createdAt     DateTime @default(now())
  userId        String?
  currency      String   @default("SOL") // "SOL" | "DORA"
  user          User?    @relation(fields: [userId], references: [id])
}

model Referral {
  id              String   @id @default(cuid())
  referrerAddress String
  referredAddress String   @unique
  createdAt       DateTime @default(now())
}

model RoundPool {
  roundId   String   @id
  yesPool   Float    @default(0)
  noPool    Float    @default(0)
  totalPool Float    @default(0)
  updatedAt DateTime @updatedAt
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
