generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id        String   @id @default(cuid())
  question  String
  category  String
  yesPool   Float    @default(0)
  noPool    Float    @default(0)
  totalPool Float    @default(0)
  status    String   @default("open") // open | closed | resolved
  endsAt    DateTime
  createdAt DateTime @default(now())
}

model Bet {
  id            String   @id @default(cuid())
  roundId       String
  walletAddress String
  side          String   // yes | no
  amount        Float
  odds          Float
  txHash        String   @unique
  status        String   @default("verified") // verified | unverified
  result        String?  // yes | no — set when round is resolved
  payout        Float?   // SOL amount sent to winner
  paid          Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Referral {
  id              String   @id @default(cuid())
  referrerAddress String
  referredAddress String   @unique
  createdAt       DateTime @default(now())
}

model RoundPool {
  roundId   String   @id
  yesPool   Float    @default(0)
  noPool    Float    @default(0)
  totalPool Float    @default(0)
  updatedAt DateTime @updatedAt
}
