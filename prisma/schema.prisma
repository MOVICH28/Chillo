generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Round {
  id              String    @id @default(cuid())
  question        String
  category        String
  yesPool         Float     @default(0)
  noPool          Float     @default(0)
  totalPool       Float     @default(0)
  status          String    @default("open") // open | closed | resolved
  endsAt          DateTime
  createdAt       DateTime  @default(now())
  targetPrice     Float?
  targetToken     String?   // "bitcoin" | "solana"
  tokenList       String?   // JSON array of pump.fun token addresses
  resolvedAt      DateTime?
  winner          String?   // "yes" | "no" — kept for pumpfun rounds
  outcomes        Json?     // Array of {id,label,minPrice,maxPrice,pool} for range rounds
  bettingClosesAt DateTime? // endsAt minus 5 min — betting locked after this
  winningOutcome  String?   // "A"|"B"|"C"|"D" — set on resolution of range rounds
  roundNumber     Int?      // sequential round number, null for old rounds
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  doraBalance   Float    @default(1000)
  createdAt     DateTime @default(now())
  bets          Bet[]
}

model Bet {
  id            String   @id @default(cuid())
  roundId       String
  walletAddress String
  side          String   // yes | no
  amount        Float
  odds          Float
  txHash        String   @unique
  status        String   @default("verified") // verified | unverified
  result        String?  // yes | no — set when round is resolved
  payout        Float?   // SOL amount sent to winner
  paid          Boolean  @default(false)
  createdAt     DateTime @default(now())
  userId        String?
  currency      String   @default("SOL") // "SOL" | "DORA"
  user          User?    @relation(fields: [userId], references: [id])
}

model Referral {
  id              String   @id @default(cuid())
  referrerAddress String
  referredAddress String   @unique
  createdAt       DateTime @default(now())
}

model RoundPool {
  roundId   String   @id
  yesPool   Float    @default(0)
  noPool    Float    @default(0)
  totalPool Float    @default(0)
  updatedAt DateTime @updatedAt
}
